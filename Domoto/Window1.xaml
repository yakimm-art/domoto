<Window x:Class="Domoto.Window1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Domoto.Views"
    Title="Domoto" Height="700" Width="1100"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    Loaded="Window_Loaded"
    StateChanged="Window_StateChanged">

    <!-- Root shell — the CornerRadius is driven by a binding to a
         dependency property on the code-behind so it flips to 0 when maximized. -->
    <Border x:Name="RootShell"
            Background="{DynamicResource AppBg}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <!-- Subtle drop shadow to lift the rounded window visually -->
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.25"
                              Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============================================== -->
            <!-- Custom title bar                                -->
            <!-- ============================================== -->
            <Border Grid.Row="0"
                    x:Name="TitleBarBorder"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0">
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="10" Height="10"
                                 Fill="{DynamicResource AppAccent}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Domoto"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls + theme toggle -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Stretch">

                        <!-- Theme toggle -->
                        <Button x:Name="BtnTheme" ToolTip="Toggle theme"
                                Click="BtnTheme_Click"
                                Width="46" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource AppText}"
                                BorderThickness="0" Cursor="Hand"
                                Content="🌙"
                                AutomationProperties.Name="Toggle theme">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource AppElevated}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Minimize -->
                        <Button x:Name="BtnMinimize" Content="—" ToolTip="Minimize"
                                Click="BtnMinimize_Click"
                                Width="46" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource AppText}"
                                BorderThickness="0" Cursor="Hand"
                                AutomationProperties.Name="Minimize window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource AppElevated}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaximize" Content="☐" ToolTip="Maximize"
                                Click="BtnMaximize_Click"
                                Width="46" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource AppText}"
                                BorderThickness="0" Cursor="Hand"
                                AutomationProperties.Name="Maximize window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource AppElevated}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Close -->
                        <Button x:Name="BtnClose" Content="✕" ToolTip="Close"
                                Click="BtnClose_Click"
                                Width="46" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource AppText}"
                                BorderThickness="0" Cursor="Hand"
                                AutomationProperties.Name="Close window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="0,14,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="#EF4444"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================== -->
            <!-- Main content area                               -->
            <!-- ============================================== -->
            <Border Grid.Row="1"
                    Background="{DynamicResource AppBg}"
                    CornerRadius="0,0,14,14">
                <Grid x:Name="MainContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" x:Name="SidebarColumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <views:SidebarView x:Name="SidebarControl"
                                       Grid.Column="0"
                                       Visibility="Collapsed"/>

                    <ContentControl x:Name="MainContent" Grid.Column="1"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
