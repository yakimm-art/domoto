<Window x:Class="Domoto.Window1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Domoto.Views"
    Title="TaskManager" Height="700" Width="1100"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip">

    <!-- Outer border gives the window its neobrutalism frame -->
    <Border Background="{StaticResource NeoBg}"
            BorderBrush="{StaticResource NeoBorder}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar — dark background to blend with sidebar -->
            <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid Background="{StaticResource NeoSidebarBg}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Domoto" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource NeoTextLight}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window control buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <!-- Minimize -->
                        <Button x:Name="BtnMinimize" Content="—" ToolTip="Minimize"
                                Click="BtnMinimize_Click"
                                Width="46" FontSize="13" FontWeight="Bold"
                                Background="Transparent" Foreground="{StaticResource NeoTextLight}"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Stretch"
                                AutomationProperties.Name="Minimize window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A3D"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaximize" Content="☐" ToolTip="Maximize"
                                Click="BtnMaximize_Click"
                                Width="46" FontSize="13" FontWeight="Bold"
                                Background="Transparent" Foreground="{StaticResource NeoTextLight}"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Stretch"
                                AutomationProperties.Name="Maximize window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A3D"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Close -->
                        <Button x:Name="BtnClose" Content="✕" ToolTip="Close"
                                Click="BtnClose_Click"
                                Width="46" FontSize="13" FontWeight="Bold"
                                Background="Transparent" Foreground="{StaticResource NeoTextLight}"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Stretch"
                                AutomationProperties.Name="Close window">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource NeoAccentPink}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content area -->
            <Grid Grid.Row="1" x:Name="MainContainer">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" x:Name="SidebarColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar (Column 0) — initially collapsed, shown after login -->
                <views:SidebarView x:Name="SidebarControl"
                                   Grid.Column="0"
                                   Visibility="Collapsed"/>

                <!-- Main content area (Column 1) — views are swapped here -->
                <ContentControl x:Name="MainContent"
                                Grid.Column="1"/>
            </Grid>
        </Grid>
    </Border>
</Window>
