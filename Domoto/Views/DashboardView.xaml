                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                                          Direction="270" Opacity="0.2"
                                                          Color="#000000"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{Binding TodayDate}"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="14"
                                           Foreground="White" Opacity="0.85"
                                           Margin="0,6,0,0"/>
