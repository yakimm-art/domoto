                                    <Run Text="{Binding CurrentUsername, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text=". Here's what's on your plate."/>
                                </TextBlock>
>>>>>>> c8e328f7aba13a7a53d0689d6725a52e49134ecd
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- ========================================== -->
                <!-- STATS                                       -->
                <!-- ========================================== -->
                <Grid Grid.Row="1" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- In progress -->
                    <Border Grid.Column="0" Style="{StaticResource AppCardElevated}" Padding="20,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6"
                                              Direction="270" Opacity="0.08"
                                              Color="#000000"/>
                        </Border.Effect>
                        <DockPanel>
                            <Border DockPanel.Dock="Left"
                                    Width="42" Height="42" CornerRadius="12"
                                    Background="#EEF2FF"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="◐" FontSize="19" FontWeight="Bold"
                                           Foreground="#6366F1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding InProgressCount}"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="{DynamicResource AppText}"/>
                                <TextBlock Text="In progress"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"/>
                                <TextBlock Text="Actively worked"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppTextSubtle}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Completed -->
                    <Border Grid.Column="2" Style="{StaticResource AppCardElevated}" Padding="20,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6"
                                              Direction="270" Opacity="0.08"
                                              Color="#000000"/>
                        </Border.Effect>
                        <DockPanel>
                            <Border DockPanel.Dock="Left"
                                    Width="42" Height="42" CornerRadius="12"
                                    Background="#ECFDF5"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="✓" FontSize="19" FontWeight="Bold"
                                           Foreground="#10B981"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CompletedCount}"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="{DynamicResource AppText}"/>
                                <TextBlock Text="Completed"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"/>
                                <TextBlock Text="All time"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppTextSubtle}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Overdue -->
