                    </Border>
                </Grid>

                <!-- ========================================== -->
                <!-- QUICK ACTIONS                               -->
                <!-- ========================================== -->
                <Border Grid.Row="2" Style="{StaticResource AppCard}"
                        Padding="18" Margin="0,0,0,26">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="{DynamicResource AppAccentSubtle}"
                                    Margin="0,0,14,0">
                                <TextBlock Text="＋" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource AppAccent}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Create a new task"
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppText}"/>
                                <TextBlock Text="Jump into the task workspace and start organizing."
                                           FontFamily="{DynamicResource AppFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Open tasks"
                                Command="{Binding NavigateToTasksCommand}"
                                Style="{StaticResource AppPrimaryButton}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ========================================== -->
                <!-- TODAY'S TASKS HEADER                        -->
                <!-- ========================================== -->
                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Due today" Style="{StaticResource AppH2}" FontSize="20"/>
                        <TextBlock Text="Tasks scheduled for the current day."
                                   Style="{StaticResource AppMuted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{DynamicResource AppElevated}"
                            CornerRadius="999"
                            Padding="12,5"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DailyTasks.Count}"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text=" scheduled"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="12"
                                       Foreground="{DynamicResource AppTextMuted}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========================================== -->
                <!-- DAILY TASKS LIST                            -->
                <!-- ========================================== -->
                <Border Grid.Row="4" Style="{StaticResource AppCard}" Padding="6">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding DailyTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Padding="16,14"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <!-- Status pill -->
                                            <Border DockPanel.Dock="Right"
                                                    CornerRadius="999"
                                                    Padding="10,3"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AppInfoSubtle}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AppSuccessSubtle}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AppDangerSubtle}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource AppInfo}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource AppSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource AppDanger}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontFamily="{DynamicResource AppFont}"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="In progress"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AppInfo}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Text" Value="Done"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppSuccess}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                        <Setter Property="Text" Value="Overdue"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDanger}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontFamily="{DynamicResource AppFont}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppText}"
                                                           TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethrough}}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Category}"
                                                               FontFamily="{DynamicResource AppFont}"
                                                               FontSize="11" FontWeight="Medium"
                                                               Foreground="{DynamicResource AppAccent}"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="•" FontSize="11"
                                                               Foreground="{DynamicResource AppTextSubtle}"
                                                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding DueDate, StringFormat='{}{0:MMM dd • h:mm tt}'}"
                                                               FontFamily="{DynamicResource AppFont}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AppTextMuted}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,40">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DailyTasks.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Width="56" Height="56" CornerRadius="16"
                                    Background="{DynamicResource AppAccentSubtle}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,14">
                                <TextBlock Text="✦" FontSize="24"
                                           Foreground="{DynamicResource AppAccent}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="All clear for today"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="No tasks due today. Plan ahead or take a break."
                                       Style="{StaticResource AppMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
