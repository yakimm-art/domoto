<UserControl x:Class="Domoto.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="{StaticResource NeoBg}" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ======================================================= -->
            <!-- WELCOME BANNER                                           -->
            <!-- ======================================================= -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <!-- Hard shadow -->
                <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                    <Border.RenderTransform>
                        <TranslateTransform X="3" Y="3"/>
                    </Border.RenderTransform>
                </Border>
                <!-- Banner card -->
                <Border Background="{StaticResource NeoCardBg}"
                        BorderBrush="{StaticResource NeoBorder}"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="28,24">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Start tracking"
                            Command="{Binding NavigateToTasksCommand}"
                            Background="{StaticResource NeoAccentBlue}"
                            Foreground="White"
                            FontSize="14"
                            Padding="20,10"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Start tracking tasks"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Daily task manager"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontHeadingLarge}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource NeoText}"/>
                        <TextBlock Text="Track, manage, and complete your tasks with ease."
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontBody}"
                                   Foreground="#666666"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </DockPanel>
                </Border>
            </Grid>

            <!-- ======================================================= -->
            <!-- STATS ROW — Three neobrutalism cards                     -->
            <!-- ======================================================= -->
            <TextBlock Grid.Row="1"
                       Text="Overview"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="{StaticResource NeoFontHeadingSmall}"
                       FontWeight="Bold"
                       Foreground="{StaticResource NeoText}"
                       Margin="0,0,0,12"/>

            <WrapPanel Grid.Row="2" Margin="0,0,0,24">
                <!-- In Progress Card -->
                <Grid Margin="0,0,16,8" Width="220">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoCardBg}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="In Progress"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabel}"
                                       FontWeight="Bold"
                                       Foreground="#666666"/>
                            <TextBlock Text="{Binding InProgressCount}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontHeadingLarge}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource NeoAccentBlue}"
                                       Margin="0,4,0,0"/>
                            <Border Background="{StaticResource NeoAccentBlue}"
                                    Height="4" CornerRadius="2"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Completed Card -->
                <Grid Margin="0,0,16,8" Width="220">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoCardBg}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Completed"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabel}"
                                       FontWeight="Bold"
                                       Foreground="#666666"/>
                            <TextBlock Text="{Binding CompletedCount}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontHeadingLarge}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource NeoAccentGreen}"
                                       Margin="0,4,0,0"/>
                            <Border Background="{StaticResource NeoAccentGreen}"
                                    Height="4" CornerRadius="2"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Overdue Card -->
                <Grid Margin="0,0,16,8" Width="220">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoCardBg}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Overdue"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabel}"
                                       FontWeight="Bold"
                                       Foreground="#666666"/>
                            <TextBlock Text="{Binding OverdueCount}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontHeadingLarge}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource NeoAccentPink}"
                                       Margin="0,4,0,0"/>
                            <Border Background="{StaticResource NeoAccentPink}"
                                    Height="4" CornerRadius="2"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </WrapPanel>

            <!-- ======================================================= -->
            <!-- RECENT PROJECTS — Static placeholder card tiles          -->
            <!-- ======================================================= -->
            <TextBlock Grid.Row="3"
                       Text="Recent Projects"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="{StaticResource NeoFontHeadingSmall}"
                       FontWeight="Bold"
                       Foreground="{StaticResource NeoText}"
                       Margin="0,0,0,12"/>

            <WrapPanel Grid.Row="4" Margin="0,0,0,24">
                <!-- Pink project card -->
                <Grid Margin="0,0,16,12" Width="180">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoAccentPink}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="16,20">
                        <StackPanel>
                            <TextBlock Text="🎨"
                                       FontSize="24"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Design System"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontBody}"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="4 tasks"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabelSmall}"
                                       Foreground="White"
                                       Opacity="0.85"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Orange project card -->
                <Grid Margin="0,0,16,12" Width="180">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoAccentOrange}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="16,20">
                        <StackPanel>
                            <TextBlock Text="📋"
                                       FontSize="24"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Sprint Planning"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontBody}"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="7 tasks"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabelSmall}"
                                       Foreground="White"
                                       Opacity="0.85"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Yellow project card -->
                <Grid Margin="0,0,16,12" Width="180">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoAccentYellow}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="16,20">
                        <StackPanel>
                            <TextBlock Text="💡"
                                       FontSize="24"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Research"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontBody}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource NeoText}"/>
                            <TextBlock Text="3 tasks"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabelSmall}"
                                       Foreground="{StaticResource NeoText}"
                                       Opacity="0.7"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Teal project card -->
                <Grid Margin="0,0,16,12" Width="180">
                    <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                        <Border.RenderTransform>
                            <TranslateTransform X="3" Y="3"/>
                        </Border.RenderTransform>
                    </Border>
                    <Border Background="{StaticResource NeoAccentTeal}"
                            BorderBrush="{StaticResource NeoBorder}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="16,20">
                        <StackPanel>
                            <TextBlock Text="🚀"
                                       FontSize="24"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Deployment"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontBody}"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="5 tasks"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="{StaticResource NeoFontLabelSmall}"
                                       Foreground="White"
                                       Opacity="0.85"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </WrapPanel>

            <!-- ======================================================= -->
            <!-- DAILY TASKS — Bound to DailyTasks collection             -->
            <!-- ======================================================= -->
            <TextBlock Grid.Row="5"
                       Text="Daily Tasks"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="{StaticResource NeoFontHeadingSmall}"
                       FontWeight="Bold"
                       Foreground="{StaticResource NeoText}"
                       Margin="0,0,0,12"/>

            <StackPanel Grid.Row="6" Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding DailyTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <!-- Hard shadow -->
                                <Border Background="{StaticResource NeoBorder}" CornerRadius="12">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="3" Y="3"/>
                                    </Border.RenderTransform>
                                </Border>
                                <!-- Task card -->
                                <Border Background="{StaticResource NeoCardBg}"
                                        BorderBrush="{StaticResource NeoBorder}"
                                        BorderThickness="2"
                                        CornerRadius="12"
                                        Padding="16,12">
                                    <DockPanel>
                                        <!-- Status badge on the right -->
                                        <Border DockPanel.Dock="Right"
                                                CornerRadius="8"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource NeoAccentBlue}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource NeoAccentGreen}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontFamily="{StaticResource NeoFontFamily}"
                                                       FontSize="{StaticResource NeoFontLabelSmall}"
                                                       FontWeight="Bold"
                                                       Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="New"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Text" Value="Done"/>
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsCompleted}" Value="False"/>
                                                                    <Condition Binding="{Binding IsOverdue}" Value="False"/>
                                                                    <Condition Binding="{Binding IsDueSoon}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Text" Value="In progress"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Task info on the left -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="{StaticResource NeoFontFamily}"
                                                       FontSize="{StaticResource NeoFontBody}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource NeoText}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Category}"
                                                           FontFamily="{StaticResource NeoFontFamily}"
                                                           FontSize="{StaticResource NeoFontLabelSmall}"
                                                           Foreground="#888888"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding DueDate, StringFormat='{}{0:MMM dd, yyyy}'}"
                                                           FontFamily="{StaticResource NeoFontFamily}"
                                                           FontSize="{StaticResource NeoFontLabelSmall}"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state message when no daily tasks -->
                <Border Padding="20,16" Margin="0,4,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DailyTasks.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="☀️" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="No tasks due today"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontBody}"
                                   Foreground="#888888"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Enjoy your free time or plan ahead!"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontLabelSmall}"
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
