<UserControl x:Class="Domoto.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="{DynamicResource AppBg}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource AppScrollViewer}">
            <Grid Margin="36,30,36,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- hero -->
                    <RowDefinition Height="Auto"/>  <!-- stats -->
                    <RowDefinition Height="Auto"/>  <!-- quick actions -->
                    <RowDefinition Height="Auto"/>  <!-- header -->
                    <RowDefinition Height="*"/>     <!-- list -->
                </Grid.RowDefinitions>

                <!-- ========================================== -->
                <!-- HERO WELCOME                                -->
                <!-- ========================================== -->
                <Border Grid.Row="0" CornerRadius="20" Padding="40,32" Margin="0,0,0,28"
                        ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#667EEA" Offset="0"/>
                            <GradientStop Color="#764BA2" Offset="0.5"/>
                            <GradientStop Color="#F093FB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="8"
                                          Direction="270" Opacity="0.25"
                                          Color="#667EEA"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Animated background circles -->
                        <Ellipse Width="400" Height="400"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-120,-100,0" Opacity="0.18">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="280" Height="280"
                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                 Margin="-100,0,0,-100" Opacity="0.12">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="180" Height="180"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Margin="200,-50,0,0" Opacity="0.08">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Start tracking →"
                                    Command="{Binding NavigateToTasksCommand}"
                                    FontFamily="{DynamicResource AppFont}"
                                    FontSize="14" FontWeight="SemiBold"
                                    Foreground="#667EEA"
                                    Background="White"
                                    Padding="22,12"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                      Direction="270" Opacity="0.15"
                                                      Color="#000000"/>
                                </Button.Effect>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                                  Direction="270" Opacity="0.15"
                                                                  Color="#000000"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                                                <Setter TargetName="bd" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="bd" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel VerticalAlignment="Center">
                                <Border Background="#40FFFFFF"
                                        CornerRadius="999"
                                        Padding="12,5"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                          Direction="270" Opacity="0.1"
                                                          Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="White"
                                                 VerticalAlignment="Center" Margin="0,0,7,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                                                  Opacity="0.6" Color="White"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock Text="Today's overview"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding WelcomeMessage}"
                                           FontFamily="{DynamicResource AppFont}"
