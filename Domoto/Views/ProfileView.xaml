<UserControl x:Class="Domoto.Views.ProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="{StaticResource NeoBg}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,40,0,40" MaxWidth="480" MinWidth="400">

                <!-- User Avatar Circle -->
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{StaticResource NeoAccentBlue}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="{Binding CurrentUsername, Converter={StaticResource FirstLetterConverter}}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Page Header -->
                <TextBlock Text="👤 Profile Settings"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource NeoText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource NeoText}" FontSize="13" Margin="0,0,0,24" Opacity="0.7">
                    <Run Text="Current: "/>
                    <Run Text="{Binding CurrentUsername}" FontWeight="SemiBold"/>
                    <Run Text=" ("/>
                    <Run Text="{Binding CurrentRole}"/>
                    <Run Text=")"/>
                </TextBlock>

                <!-- Update Username Card -->
                <Border Style="{StaticResource NeoCard}" Margin="0,0,0,20">
                    <Grid>
                        <!-- Hard shadow -->
                        <Border Background="{StaticResource NeoBorder}"
                                CornerRadius="12"
                                Margin="3,3,-3,-3"/>
                        <!-- Card content -->
                        <Border Background="{StaticResource NeoCardBg}"
                                BorderBrush="{StaticResource NeoBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="24">
                            <StackPanel>
                                <TextBlock Text="Change Username"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource NeoText}"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="New Username"
                                           Foreground="{StaticResource NeoText}"
                                           FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>
                                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,16"/>
                                <Button Content="Update Username"
                                        Command="{Binding UpdateProfileCommand}"
                                        Background="{StaticResource NeoAccentBlue}"
                                        Foreground="White"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Change Password Card -->
                <Border Style="{StaticResource NeoCard}" Margin="0,0,0,20">
                    <Grid>
                        <!-- Hard shadow -->
                        <Border Background="{StaticResource NeoBorder}"
                                CornerRadius="12"
                                Margin="3,3,-3,-3"/>
                        <!-- Card content -->
                        <Border Background="{StaticResource NeoCardBg}"
                                BorderBrush="{StaticResource NeoBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="24">
                            <StackPanel>
                                <TextBlock Text="Change Password"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource NeoText}"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="New Password"
                                           Foreground="{StaticResource NeoText}"
                                           FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>
                                <PasswordBox x:Name="PwdNew"
                                             Margin="0,0,0,12"
                                             PasswordChanged="PwdNew_PasswordChanged"/>

                                <TextBlock Text="Confirm Password"
                                           Foreground="{StaticResource NeoText}"
                                           FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>
                                <PasswordBox x:Name="PwdConfirm"
                                             Margin="0,0,0,16"
                                             PasswordChanged="PwdConfirm_PasswordChanged"/>

                                <Button Content="Change Password"
                                        Command="{Binding ChangePasswordCommand}"
                                        Background="{StaticResource NeoAccentGreen}"
                                        Foreground="White"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Profile Message -->
                <TextBlock Text="{Binding ProfileMessage}"
                           Foreground="{StaticResource NeoAccentPink}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
