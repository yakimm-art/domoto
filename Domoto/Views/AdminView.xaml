<UserControl x:Class="Domoto.Views.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="{StaticResource NeoBg}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,32,32,32" MaxWidth="900">

                <!-- Page Header -->
                <TextBlock Text="🔧 Admin Panel"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource NeoText}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Manage users and roles"
                           Foreground="{StaticResource NeoText}"
                           FontSize="13" Margin="0,0,0,24" Opacity="0.7"/>

                <!-- User List Card -->
                <Border Margin="0,0,0,24">
                    <Grid>
                        <!-- Hard shadow -->
                        <Border Background="{StaticResource NeoBorder}"
                                CornerRadius="12"
                                Margin="3,3,-3,-3"/>
                        <!-- Card content -->
                        <Border Background="{StaticResource NeoCardBg}"
                                BorderBrush="{StaticResource NeoBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Users"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="{StaticResource NeoText}"
                                               VerticalAlignment="Center"/>
                                    <!-- User count badge -->
                                    <Border Background="{StaticResource NeoAccentBlue}"
                                            CornerRadius="10"
                                            Padding="8,2"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Users.Count}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>

                                <DataGrid ItemsSource="{Binding Users}"
                                          SelectedItem="{Binding SelectedUser}"
                                          IsReadOnly="True"
                                          Margin="0,0,0,0"
                                          AutomationProperties.Name="User list">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                                        <DataGridTemplateColumn Header="Actions" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Delete" Cursor="Hand"
                                                            Background="{StaticResource NeoAccentPink}"
                                                            Foreground="White"
                                                            Padding="10,4" FontSize="11"
                                                            Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Add User Form Card -->
                <Border Margin="0,0,0,20">
                    <Grid>
                        <!-- Hard shadow -->
                        <Border Background="{StaticResource NeoBorder}"
                                CornerRadius="12"
                                Margin="3,3,-3,-3"/>
                        <!-- Card content -->
                        <Border Background="{StaticResource NeoCardBg}"
                                BorderBrush="{StaticResource NeoBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="24">
                            <StackPanel>
                                <TextBlock Text="Add New User"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource NeoText}"
                                           Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Labels -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Username"
                                               Foreground="{StaticResource NeoText}"
                                               FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="Password"
                                               Foreground="{StaticResource NeoText}"
                                               FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4"
                                               Text="Role"
                                               Foreground="{StaticResource NeoText}"
                                               FontSize="12" Margin="0,0,0,6" Opacity="0.7"/>

                                    <!-- Inputs -->
                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="New username"/>
                                    <PasswordBox Grid.Row="2" Grid.Column="2"
                                                 x:Name="AdminPwd"
                                                 PasswordChanged="AdminPwd_PasswordChanged"
                                                 AutomationProperties.Name="New password"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4"
                                              Width="120"
                                              SelectedItem="{Binding NewRole}"
                                              AutomationProperties.Name="Role">
                                        <sys:String>User</sys:String>
                                        <sys:String>Admin</sys:String>
                                    </ComboBox>
                                </Grid>

                                <Button Content="Add User"
                                        Command="{Binding AddUserCommand}"
                                        Background="{StaticResource NeoAccentGreen}"
                                        Foreground="White"
                                        HorizontalAlignment="Left"
                                        Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
