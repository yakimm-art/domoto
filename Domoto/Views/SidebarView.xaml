<UserControl x:Class="Domoto.Views.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <UserControl.Resources>
    </UserControl.Resources>

    <Border Background="{DynamicResource AppSidebarBg}"
            BorderBrush="{DynamicResource AppSidebarBorder}"
            BorderThickness="0,0,1,0"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER WITH COLLAPSE BUTTON -->
            <DockPanel Grid.Row="0" Margin="6,22,6,18">
                <Button DockPanel.Dock="Right"
                        Command="{Binding ToggleSidebarCommand}"
                        Width="32" Height="32"
                        Margin="0"
                        ToolTip="Toggle sidebar">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AppIconButton}">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <TextBlock Text="‹" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource AppSidebarMuted}"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <TextBlock Text="›" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AppSidebarMuted}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- BRAND -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="9" Margin="0,0,4,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource AppGradStart}" Offset="0"/>
                                <GradientStop Color="{DynamicResource AppGradEnd}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="D" Foreground="White"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center"
                                Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="Domoto"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource AppSidebarText}"/>
                        <TextBlock Text="Workspace"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppSidebarMuted}"
                                   Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- SEARCH -->
            <Border Grid.Row="1" Margin="16,0,16,18"
                    Background="{DynamicResource AppHover}"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="9"
                    Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBool}}">
                <DockPanel Margin="12,0,10,0">
                    <TextBlock DockPanel.Dock="Left" Text="🔍"
                               FontSize="11"
                               Foreground="{DynamicResource AppSidebarMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{DynamicResource AppFont}"
                             FontSize="12"
                             Height="34"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             Foreground="{DynamicResource AppSidebarText}"
                             CaretBrush="{DynamicResource AppSidebarText}"
                             VerticalContentAlignment="Center"
                             ToolTip="Search tasks..."
                             AutomationProperties.Name="Search tasks"/>
                </DockPanel>
            </Border>

            <!-- NAV -->
            <StackPanel Grid.Row="2" Margin="0,4,0,0">
                <TextBlock Text="MENU"
                           FontFamily="{DynamicResource AppFont}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource AppSidebarMuted}"
                           Margin="22,4,20,8"
                           Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBool}}"/>

                <!-- Home -->
                <Button Command="{Binding NavigateHomeCommand}" Cursor="Hand" Margin="10,1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="rail" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="2"
                                        Margin="0,6,4,6"/>
                                <Border x:Name="bd" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Padding="10,9">
                                    <DockPanel>
                                        <Border x:Name="iconBg" DockPanel.Dock="Left"
                                                Width="24" Height="24" CornerRadius="7"
                                                Background="{DynamicResource AppHover}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="⌂" FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource AppSidebarMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Dashboard"
                                                   Foreground="{DynamicResource AppSidebarText}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding DataContext.IsCollapsed, Converter={StaticResource InverseBool}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarHover}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding ActiveNavItem}" Value="Home">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarActive}"/>
                                    <Setter TargetName="rail" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                    <Setter TargetName="iconBg" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Tasks -->
                <Button Command="{Binding NavigateTasksCommand}" Cursor="Hand" Margin="10,1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="rail" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="2"
                                        Margin="0,6,4,6"/>
                                <Border x:Name="bd" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Padding="10,9">
                                    <DockPanel>
                                        <Border x:Name="iconBg" DockPanel.Dock="Left"
                                                Width="24" Height="24" CornerRadius="7"
                                                Background="{DynamicResource AppHover}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource AppSidebarMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Tasks"
                                                   Foreground="{DynamicResource AppSidebarText}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding DataContext.IsCollapsed, Converter={StaticResource InverseBool}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarHover}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding ActiveNavItem}" Value="Tasks">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarActive}"/>
                                    <Setter TargetName="rail" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                    <Setter TargetName="iconBg" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Profile -->
                <Button Command="{Binding NavigateProfileCommand}" Cursor="Hand" Margin="10,1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="rail" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="2"
                                        Margin="0,6,4,6"/>
                                <Border x:Name="bd" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Padding="10,9">
                                    <DockPanel>
                                        <Border x:Name="iconBg" DockPanel.Dock="Left"
                                                Width="24" Height="24" CornerRadius="7"
                                                Background="{DynamicResource AppHover}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="◉" FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource AppSidebarMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Profile"
                                                   Foreground="{DynamicResource AppSidebarText}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding DataContext.IsCollapsed, Converter={StaticResource InverseBool}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarHover}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding ActiveNavItem}" Value="Profile">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarActive}"/>
                                    <Setter TargetName="rail" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                    <Setter TargetName="iconBg" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Admin -->
                <Button Command="{Binding NavigateAdminCommand}" Cursor="Hand" Margin="10,1"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="rail" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="2"
                                        Margin="0,6,4,6"/>
                                <Border x:Name="bd" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Padding="10,9">
                                    <DockPanel>
                                        <Border x:Name="iconBg" DockPanel.Dock="Left"
                                                Width="24" Height="24" CornerRadius="7"
                                                Background="{DynamicResource AppHover}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="⚙" FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource AppSidebarMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Admin"
                                                   Foreground="{DynamicResource AppSidebarText}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="13" FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding DataContext.IsCollapsed, Converter={StaticResource InverseBool}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarHover}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding ActiveNavItem}" Value="Admin">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource AppSidebarActive}"/>
                                    <Setter TargetName="rail" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                    <Setter TargetName="iconBg" Property="Background"
                                            Value="{DynamicResource AppAccent}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Upgrade promo card -->
                <Border Margin="16,24,16,0"
                        Background="{DynamicResource AppAccentSubtle}"
                        CornerRadius="12"
                        Padding="14"
                        Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBool}}">
                    <StackPanel>
                        <TextBlock Text="✦ Pro tip"
                                   FontFamily="{DynamicResource AppFont}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource AppAccent}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Use priorities and due dates to sort your day."
                                   FontFamily="{DynamicResource AppFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppText}"
                                   TextWrapping="Wrap"
                                   LineHeight="16"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- USER FOOTER -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource AppSidebarBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,12">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource AppIconButton}"
                            Content="⎋"
                            ToolTip="Logout"
                            FontSize="15"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Logout"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBool}}">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource AppGradStart}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource AppGradEnd}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding CurrentUsername, Converter={StaticResource FirstLetterConverter}}"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUsername}"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppSidebarText}"/>
                            <TextBlock Text="{Binding CurrentRole}"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppSidebarMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
