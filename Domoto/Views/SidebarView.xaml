<UserControl x:Class="Domoto.Views.SidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="260"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="{StaticResource NeoSidebarBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App Title -->
        <TextBlock Grid.Row="0"
                   Text="Domoto"
                   FontFamily="{StaticResource NeoFontFamily}"
                   FontSize="{StaticResource NeoFontHeading}"
                   FontWeight="Bold"
                   Foreground="{StaticResource NeoTextLight}"
                   Margin="20,20,20,12"/>

        <!-- Search Bar -->
        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="{StaticResource NeoFontFamily}"
                 FontSize="{StaticResource NeoFontBodySmall}"
                 Background="#2A2A3D"
                 Foreground="{StaticResource NeoTextLight}"
                 BorderBrush="#3A3A50"
                 BorderThickness="2"
                 Padding="10,8"
                 Margin="16,0,16,16"
                 ToolTip="Search tasks..."
                 AutomationProperties.Name="Search tasks"/>

        <!-- Navigation Section -->
        <StackPanel Grid.Row="2" Margin="0,4,0,0">

            <!-- Section Header -->
            <TextBlock Text="NAVIGATION"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="{StaticResource NeoFontLabelSmall}"
                       FontWeight="Bold"
                       Foreground="#6C6C8A"
                       Margin="20,0,20,8"/>

            <!-- Separator line between header and nav items -->
            <Border Height="1" Background="#3A3A50" Margin="16,0,16,8"/>

            <!-- Home -->
            <Button Command="{Binding NavigateHomeCommand}" Cursor="Hand" Margin="0,0,0,2">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="NavBorder"
                                            Background="Transparent"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="20,10,16,10">
                                        <TextBlock Text="🏠  Home"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="{StaticResource NeoFontBody}"
                                                   Foreground="{StaticResource NeoTextLight}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding ActiveNavItem}" Value="Home">
                                            <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource NeoAccentBlue}"/>
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Tasks -->
            <Button Command="{Binding NavigateTasksCommand}" Cursor="Hand" Margin="0,0,0,2">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="NavBorder"
                                            Background="Transparent"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="20,10,16,10">
                                        <TextBlock Text="📋  Tasks"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="{StaticResource NeoFontBody}"
                                                   Foreground="{StaticResource NeoTextLight}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding ActiveNavItem}" Value="Tasks">
                                            <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource NeoAccentBlue}"/>
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Profile -->
            <Button Command="{Binding NavigateProfileCommand}" Cursor="Hand" Margin="0,0,0,2">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="NavBorder"
                                            Background="Transparent"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="20,10,16,10">
                                        <TextBlock Text="👤  Profile"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="{StaticResource NeoFontBody}"
                                                   Foreground="{StaticResource NeoTextLight}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding ActiveNavItem}" Value="Profile">
                                            <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource NeoAccentBlue}"/>
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Admin (visible only when IsAdmin is true) -->
            <Button Command="{Binding NavigateAdminCommand}" Cursor="Hand" Margin="0,0,0,2"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="NavBorder"
                                            Background="Transparent"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="20,10,16,10">
                                        <TextBlock Text="🔧  Admin"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="{StaticResource NeoFontBody}"
                                                   Foreground="{StaticResource NeoTextLight}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding ActiveNavItem}" Value="Admin">
                                            <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource NeoAccentBlue}"/>
                                            <Setter TargetName="NavBorder" Property="Background" Value="#2A2A3D"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- User Info + Logout at bottom -->
        <Border Grid.Row="3"
                BorderBrush="#3A3A50"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding LogoutCommand}"
                        Content="Logout"
                        FontFamily="{StaticResource NeoFontFamily}"
                        FontSize="{StaticResource NeoFontLabelSmall}"
                        FontWeight="Bold"
                        Foreground="{StaticResource NeoAccentPink}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Logout">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- User avatar circle -->
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{StaticResource NeoAccentBlue}"
                            Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUsername, Converter={StaticResource FirstLetterConverter}}"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUsername}"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontBody}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource NeoTextLight}"/>
                        <TextBlock Text="{Binding CurrentRole}"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="{StaticResource NeoFontLabelSmall}"
                                   Foreground="#6C6C8A"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
