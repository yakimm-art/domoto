<UserControl x:Class="Domoto.Views.TaskView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
    SizeChanged="TaskView_SizeChanged">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddTaskCommand}"/>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveTaskCommand}"/>
        <KeyBinding Modifiers="Control" Key="E" Command="{Binding EditTaskCommand}"
                    CommandParameter="{Binding SelectedTask}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteTaskCommand}"
                    CommandParameter="{Binding SelectedTask}"/>
        <KeyBinding Key="Space" Command="{Binding ToggleCompleteCommand}"
                    CommandParameter="{Binding SelectedTask}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding EscapeCommand}"/>
    </UserControl.InputBindings>

    <Grid Background="{DynamicResource AppBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="FormPanelColumn" Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================= -->
        <!-- LEFT                                               -->
        <!-- ================================================= -->
        <Grid Grid.Column="0" Margin="36,30,26,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Border Background="{DynamicResource AppAccentSubtle}"
                            CornerRadius="999" Padding="10,4"
                            HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock Text="Workspace"
                                   FontFamily="{DynamicResource AppFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppAccent}"/>
                    </Border>
                    <TextBlock Text="My tasks"
                               FontFamily="{DynamicResource AppFont}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource AppText}"/>
                    <TextBlock Text="Plan, prioritize, and track everything in one place."
                               Style="{StaticResource AppMuted}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding AddTaskCommand}"
                        Style="{StaticResource AppPrimaryButton}"
                        VerticalAlignment="Center"
                        Padding="18,11">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="New task" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Keyboard shortcuts help button -->
                <Button Grid.Column="1" HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="-44,0,0,0"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="Keyboard shortcuts"
                        x:Name="HelpButton"
                        Click="HelpButton_Click"
                        Content="?"
                        FontSize="13"
                        FontWeight="Bold"/>

                <!-- Shortcuts popup -->
                <Popup x:Name="ShortcutsPopup"
                       PlacementTarget="{Binding ElementName=HelpButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,14"
                            Effect="{StaticResource AppShadow}">
                        <StackPanel>
                            <TextBlock Text="Keyboard Shortcuts"
                                       FontFamily="{DynamicResource AppFont}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource AppText}"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2"><TextBlock Text="Ctrl+N" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="New task" Style="{StaticResource AppMuted}" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Ctrl+S" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Save task" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Ctrl+E" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Edit selected task" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="3" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Space" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Toggle complete" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="4" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Delete" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Delete selected task" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="5" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Ctrl+F" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Focus search" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="6" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="F5" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Refresh tasks" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                <Border Grid.Row="7" Grid.Column="0" Background="{DynamicResource AppElevated}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0"><TextBlock Text="Esc" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource AppText}"/></Border>
                                <TextBlock Grid.Row="7" Grid.Column="2" Text="Discard / clear form" Style="{StaticResource AppMuted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <!-- STAT PILLS -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,22">
                <Border Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="999" Padding="14,7"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total"
                                   FontFamily="{DynamicResource AppFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding TotalTasks}"
                                   FontFamily="{DynamicResource AppFont}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource AppText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource AppSuccessSubtle}"
                        CornerRadius="999" Padding="14,7" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource AppSuccess}"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock FontFamily="{DynamicResource AppFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSuccess}"
                                   VerticalAlignment="Center">
                            <Run Text="Done "/><Run Text="{Binding CompletedTasks, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource AppWarningSubtle}"
                        CornerRadius="999" Padding="14,7" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource AppWarning}"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock FontFamily="{DynamicResource AppFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppWarning}"
                                   VerticalAlignment="Center">
                            <Run Text="Pending "/><Run Text="{Binding PendingTasks, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource AppDangerSubtle}"
                        CornerRadius="999" Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource AppDanger}"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock FontFamily="{DynamicResource AppFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppDanger}"
                                   VerticalAlignment="Center">
                            <Run Text="Overdue "/><Run Text="{Binding OverdueTasks, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- FILTER BAR -->
            <Border Grid.Row="2" Style="{StaticResource AppCardElevated}" Padding="16" Margin="0,0,0,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource AppElevated}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="🔍"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{DynamicResource AppFont}"
                                         FontSize="13"
                                         Height="36"
                                         Background="Transparent"
                                         Foreground="{DynamicResource AppText}"
                                         CaretBrush="{DynamicResource AppText}"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Padding="0"
                                         ToolTip="Search title, description, or category"/>
                            </DockPanel>
                        </Border>

                        <Button Grid.Column="1"
                                Content="Clear"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource AppSecondaryButton}"
                                Margin="10,0,0,0"/>
                        <Button Grid.Column="2"
                                Command="{Binding ExportCsvCommand}"
                                Style="{StaticResource AppSecondaryButton}"
                                Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇣" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Export"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Priority" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding FilterPriorities}"
                                      SelectedItem="{Binding FilterPriority}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Category" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding FilterCategories}"
                                      SelectedItem="{Binding FilterCategory}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Status" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding FilterStatuses}"
                                      SelectedItem="{Binding FilterStatus}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Sort by" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SortBy}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- TASK LIST -->
            <ListBox Grid.Row="3"
                     ItemsSource="{Binding TasksView}"
                     SelectedItem="{Binding SelectedTask}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- Priority accent bar on left edge -->
                            <Border Width="4" HorizontalAlignment="Left"
                                    CornerRadius="2,0,0,2"
                                    Margin="0,2,0,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AppSuccess}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Priority}" Value="High">
                                                <Setter Property="Background" Value="{DynamicResource AppDanger}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                <Setter Property="Background" Value="{DynamicResource AppWarning}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Border x:Name="Card"
                                    Background="{DynamicResource AppSurface}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,16,18,16"
                                    Margin="4,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AppSurface}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrong}"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="12"
                                                                          ShadowDepth="2"
                                                                          Direction="270"
                                                                          Opacity="0.08"
                                                                          Color="#000000"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              Style="{StaticResource AppCheckBox}"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              VerticalAlignment="Top"
                                              Margin="0,3,14,0"
                                              Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppText}"
                                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethrough}}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontFamily="{DynamicResource AppFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,10"/>
                                        <WrapPanel>
                                            <Border CornerRadius="999" Padding="9,3" Margin="0,0,6,6"
                                                    Background="{DynamicResource AppAccentSubtle}">
                                                <TextBlock Text="{Binding Category}"
                                                           FontFamily="{DynamicResource AppFont}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppAccent}"/>
                                            </Border>
                                            <Border CornerRadius="999" Padding="9,3" Margin="0,0,6,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AppSuccessSubtle}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="High">
                                                                <Setter Property="Background" Value="{DynamicResource AppDangerSubtle}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                                <Setter Property="Background" Value="{DynamicResource AppWarningSubtle}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="5" Height="5"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,5,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource AppSuccess}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="High">
                                                                        <Setter Property="Fill" Value="{DynamicResource AppDanger}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                                        <Setter Property="Fill" Value="{DynamicResource AppWarning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock FontFamily="{DynamicResource AppFont}"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppSuccess}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="High">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDanger}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppWarning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding Priority, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border CornerRadius="999" Padding="9,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AppElevated}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AppDangerSubtle}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontFamily="{DynamicResource AppFont}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppDanger}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="Due "/><Run Text="{Binding DueDate, StringFormat='{}{0:MMM dd}', Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource AppIconButton}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="✎"
                                                FontSize="14"/>
                                        <Button Style="{StaticResource AppIconButton}"
                                                ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="🗑"
                                                FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ================================================= -->
        <!-- RIGHT: Form panel                                  -->
        <!-- ================================================= -->
        <Border Grid.Column="1"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource AppScrollViewer}">
                <StackPanel Margin="30,30,30,30">
                    <!-- Form header with icon -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{DynamicResource AppAccentSubtle}"
                                Margin="0,0,12,0">
                            <TextBlock FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource AppAccent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="＋"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="✎"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding FormTitle}" Style="{StaticResource AppH2}"/>
                            <TextBlock Text="Fill out the details below."
                                       Style="{StaticResource AppMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource AppBorder}"
                            Margin="0,18,0,18"/>

                    <TextBlock Text="Title" Style="{StaticResource AppFieldLabel}"/>
                    <TextBox Style="{StaticResource AppInput}"
                             Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Description" Style="{StaticResource AppFieldLabel}"/>
                    <TextBox Style="{StaticResource AppInputMultiline}"
                             Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}"
                             Height="100"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Due date" Style="{StaticResource AppFieldLabel}"/>
                    <DatePicker Style="{StaticResource AppDatePicker}"
                                SelectedDate="{Binding TaskDueDate}"
                                Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Priority" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding Priorities}"
                                      SelectedItem="{Binding TaskPriority}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Category" Style="{StaticResource AppFieldLabel}"/>
                            <ComboBox Style="{StaticResource AppCombo}"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding TaskCategory}"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Save task"
                            Command="{Binding SaveTaskCommand}"
                            Style="{StaticResource AppPrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="14,12"
                            Margin="0,0,0,10"/>
                    <Button Content="Clear form"
                            Command="{Binding ClearFormCommand}"
                            Style="{StaticResource AppSecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="14,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
