<UserControl x:Class="Domoto.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid>
        <!-- Subtle radial gradient background -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                <GradientStop Color="White" Offset="0"/>
                <GradientStop Color="#F5F5F0" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>
        <!-- Outer card container with hard shadow -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
              MinWidth="400" MaxWidth="440">
            <!-- Hard shadow (3px offset, no blur) -->
            <Border Background="{StaticResource NeoBorder}"
                    CornerRadius="12"
                    Margin="0,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform X="3" Y="3"/>
                </Border.RenderTransform>
            </Border>
            <!-- Main card surface -->
            <Border Background="{StaticResource NeoCardBg}"
                    BorderBrush="{StaticResource NeoBorder}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="40">
                <StackPanel>
                    <!-- App Title -->
                    <TextBlock Text="📋 Domoto" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource NeoAccentBlue}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Manage your tasks efficiently" FontSize="13"
                               Foreground="{StaticResource NeoText}" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Divider line between title and form -->
                    <Border Height="1" Background="{StaticResource NeoBorder}" Opacity="0.15"
                            Margin="0,0,0,20"/>

                    <!-- Login Panel -->
                    <StackPanel x:Name="LoginPanel"
                                Visibility="{Binding IsNotRegistering, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Sign In" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource NeoText}" Margin="0,0,0,16"/>

                        <TextBlock Text="Username" Foreground="{StaticResource NeoText}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 AutomationProperties.Name="Username"/>

                        <TextBlock Text="Password" Foreground="{StaticResource NeoText}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"
                                     PasswordChanged="PasswordBox_PasswordChanged"
                                     AutomationProperties.Name="Password"/>

                        <Button Content="Sign In" Command="{Binding LoginCommand}"
                                Background="{StaticResource NeoAccentBlue}"
                                Foreground="{StaticResource NeoTextLight}"
                                FontSize="14" Margin="0,0,0,12"
                                AutomationProperties.Name="Sign In"/>

                        <Button Content="Create an account" Command="{Binding ShowRegisterCommand}"
                                Background="Transparent" Foreground="{StaticResource NeoAccentBlue}"
                                BorderThickness="0" FontSize="13" FontWeight="Normal"
                                AutomationProperties.Name="Create an account"/>
                    </StackPanel>

                    <!-- Register Panel -->
                    <StackPanel x:Name="RegisterPanel"
                                Visibility="{Binding IsRegistering, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Create Account" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource NeoText}" Margin="0,0,0,16"/>

                        <TextBlock Text="Username" Foreground="{StaticResource NeoText}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding RegisterUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password" Foreground="{StaticResource NeoText}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegPasswordBox" Margin="0,0,0,12"
                                     PasswordChanged="RegPasswordBox_PasswordChanged"/>

                        <TextBlock Text="Confirm Password" Foreground="{StaticResource NeoText}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegConfirmPasswordBox" Margin="0,0,0,16"
                                     PasswordChanged="RegConfirmPasswordBox_PasswordChanged"/>

                        <Button Content="Register" Command="{Binding RegisterCommand}"
                                Background="{StaticResource NeoAccentGreen}"
                                Foreground="{StaticResource NeoTextLight}"
                                FontSize="14" Margin="0,0,0,12"/>

                        <Button Content="Back to Sign In" Command="{Binding BackToLoginCommand}"
                                Background="Transparent" Foreground="{StaticResource NeoAccentBlue}"
                                BorderThickness="0" FontSize="13" FontWeight="Normal"/>
                    </StackPanel>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource NeoAccentPink}"
                               FontSize="12" FontWeight="SemiBold" Margin="0,12,0,0" TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
