<UserControl x:Class="Domoto.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" /> <!-- Form Area -->
            <ColumnDefinition Width="1*" /> <!-- Branded Sidebar -->
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: Login Form -->
        <Grid Grid.Column="0" Margin="60,20">
            <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" MaxWidth="350"
                        Visibility="{Binding IsNotRegistering, Converter={StaticResource BoolToVis}}">
                
                <TextBlock Text="📋 Domoto" FontSize="20" FontWeight="Bold" 
                           Foreground="#3A8DFF" Margin="0,0,0,40"/>

                <TextBlock Text="Login" FontSize="32" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="Welcome back! Please enter your details." 
                           Foreground="#666" Margin="0,0,0,30"/>

                <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Height="40" VerticalContentAlignment="Center"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,20" Padding="10,0"/>

                <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="40" VerticalContentAlignment="Center"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,30" Padding="10,0"/>

                <Button Content="Sign In" Command="{Binding LoginCommand}"
                        Height="45" Background="#3A8DFF" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Margin="0,0,0,15">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </Button.Resources>
                </Button>

                <Button Content="Don't have an account? Sign up" Command="{Binding ShowRegisterCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="#3A8DFF"
                        HorizontalAlignment="Center" Cursor="Hand"/>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,15,0,0" TextAlignment="Center"/>
            </StackPanel>

            <!-- Register Panel (Simplified) -->
            <StackPanel x:Name="RegisterPanel" VerticalAlignment="Center" MaxWidth="350"
                        Visibility="{Binding IsRegistering, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Create Account" FontSize="32" FontWeight="Bold" Margin="0,0,0,30"/>
                
                <!-- Reuse input patterns from above for your RegisterUsername, etc. -->
                
                <Button Content="Back to Sign In" Command="{Binding BackToLoginCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="#3A8DFF" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT SIDE: Blue Decorative Sidebar -->
        <Border Grid.Column="1" Margin="20">
            <Border CornerRadius="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A5ABF" Offset="0"/>
                        <GradientStop Color="#3A8DFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel MaxWidth="400">
                        <TextBlock Text="Welcome to Domoto" Foreground="White" FontSize="28" 
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Effortlessly manage your tasks with simple coordination. Organize your Domoto experience today." 
                                   Foreground="White" FontSize="16" TextAlignment="Center" TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>